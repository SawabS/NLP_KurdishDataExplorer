# Copy this file to .env, then set your OpenAI API key.
OPENAI_API_KEY=sk-your-key-here

# Optional: hosted embedding model used for new pipeline runs.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: set to minilm or kdx-minilm-tsdae to force the original local model.
# KDX_EMBEDDING_PROVIDER=openai